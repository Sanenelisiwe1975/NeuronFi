# ============================================================
#  NeuronFi — Autonomous DeFi Agent — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
# ============================================================

# ── Network ──────────────────────────────────────────────────
# Target network (used for logging / contract routing)
NETWORK=kite

# Kite chain JSON-RPC endpoint
KITE_RPC_URL=https://rpc.kite.ai

# Kite chain ID
KITE_CHAIN_ID=2368

# ── Kite AA SDK ───────────────────────────────────────────────
# Private key for the smart account owner (AA wallet)
# Generate a NEW key — never reuse a hardware wallet key.
AGENT_PRIVATE_KEY=0x...

# Kite paymaster URL — sponsors all gas fees (agent txs are gasless)
KITE_PAYMASTER_URL=https://paymaster.kite.ai

# ── Kite Agent Passport ───────────────────────────────────────
# Kite Agent Passport registry contract address
KITE_AGENT_PASSPORT_ADDRESS=

# ── Kite Attestation Registry ─────────────────────────────────
# Contract address for writing on-chain AI decision attestations
KITE_ATTESTATION_REGISTRY=

# ── Token Contract Addresses ─────────────────────────────────
# USDC ERC-20 contract on Kite chain — base trading/settlement asset
USDC_CONTRACT_ADDRESS=

# ── LLM / AI ─────────────────────────────────────────────────
# Anthropic API key for Claude (used by LangChain.js in packages/planner)
# Get one at https://console.anthropic.com
# If absent, the agent falls back to a deterministic mock planner (no trades).
ANTHROPIC_API_KEY=sk-ant-...

# LLM model to use for reasoning (default: claude-sonnet-4-6)
LLM_MODEL=claude-sonnet-4-6

# LLM temperature (0 = deterministic, 1 = creative; default: 0.2 for finance)
LLM_TEMPERATURE=0.2

# ── Agent Loop ────────────────────────────────────────────────
# How often the agent runs its full Observe→Reason→Decide→Execute→Resolve→Learn loop
# Value in milliseconds. Default: 60000 (60 seconds)
AGENT_LOOP_INTERVAL_MS=60000

# Set to "true" to log planned actions without submitting transactions.
# ALWAYS start with dry-run=true and verify behaviour before going live.
AGENT_DRY_RUN=true

# Maximum number of loop iterations (leave blank to run indefinitely)
# AGENT_MAX_ITERATIONS=10

# ── Risk Controls ─────────────────────────────────────────────
# Minimum expected value for a trade to be approved (default: 0.02 = 2%)
AGENT_MIN_EV=0.02

# Maximum risk score (0–100) for a trade to be approved (default: 70)
AGENT_MAX_RISK_SCORE=70

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string — Neon (https://neon.tech) free tier recommended
DATABASE_URL=postgresql://agent:password@localhost:5432/defi_agent

# Redis connection URL — Upstash (https://upstash.com) free tier recommended
REDIS_URL=redis://localhost:6379

# ── Smart Contracts ───────────────────────────────────────────
# AgentVault contract address (deployed to Kite chain)
AGENT_VAULT_ADDRESS=

# PredictionMarket factory contract address
MARKET_FACTORY_ADDRESS=

# MarketResolver contract address
# When set, the agent acts as AI oracle: proposes outcomes for expired markets,
# writes attestations to Kite Attestation Registry, and finalises after 24h dispute window.
MARKET_RESOLVER_ADDRESS=

# ConditionalPayment contract address
CONDITIONAL_PAYMENT_ADDRESS=

# SubscriptionManager contract address
SUBSCRIPTION_MANAGER_ADDRESS=

# Treasury address — receives performance fees from ConditionalPayment
TREASURY_ADDRESS=

# Private key of the deployer account (for contract deployment scripts only)
# Leave blank after deployment — agent uses AGENT_PRIVATE_KEY for execution
DEPLOYER_PRIVATE_KEY=

# ── Cross-Chain Bridge (optional) ─────────────────────────────
# Enable LayerZero cross-chain USDC bridging
LAYERZERO_BRIDGE_ENABLED=false

# ── Monitoring ────────────────────────────────────────────────
# Port for the Next.js dashboard (apps/web)
NEXT_PUBLIC_DASHBOARD_PORT=3000

# Kite block explorer base URL (used for tx/address links in the dashboard)
NEXT_PUBLIC_KITE_EXPLORER_URL=https://explorer.kite.ai
